{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": 0,
  "background": "#fffaf0",
  "width": 300,
  "height": 300,
  "data": {"url": "hopping.csv"},
  "transform": [
    {"calculate": "2", "as": "human_hop"},
    {"calculate": "datum.max_hop_m - 2", "as": "gap_vs_human"}
  ],
  "layer": [
    {
      "mark": {"type": "rule", "stroke": "#c9a96e", "strokeWidth": 3, "opacity": 0.75},
      "encoding": {
        "y": {
          "field": "species",
          "type": "nominal",
          "sort": {"field": "max_hop_m", "order": "descending"},
          "title": null,
          "axis": {
            "labelFontSize": 11,
            "labelColor": "#3d2c1a",
            "labelPadding": 6,
            "labelLineHeight": 12,
            "labelExpr": "test(/ Kangaroo$/, datum.value) ? [replace(datum.value, ' Kangaroo', ''), 'Kangaroo'] : (test(/ Wallaby$/, datum.value) ? [replace(datum.value, ' Wallaby', ''), 'Wallaby'] : datum.value)"
          }
        },
        "x": {
          "field": "human_hop",
          "type": "quantitative",
          "title": "Horizontal hop (m)",
          "scale": {"domain": [0, 10]},
          "axis": {"grid": true, "gridColor": "#efe3c8", "gridDash": [2, 4]}
        },
        "x2": {"field": "max_hop_m"}
      }
    },
    {
      "mark": {"type": "circle", "size": 220, "color": "#b54e1f", "stroke": "#fffaf0", "strokeWidth": 2},
      "encoding": {
        "y": {"field": "species", "type": "nominal", "sort": {"field": "max_hop_m", "order": "descending"}},
        "x": {"field": "max_hop_m", "type": "quantitative"},
        "tooltip": [
          {"field": "species", "type": "nominal", "title": "Species"},
          {"field": "max_hop_m", "type": "quantitative", "title": "Horizontal hop (m)"},
          {"field": "gap_vs_human", "type": "quantitative", "title": "Gap vs human (m)"}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "baseline": "middle", "dx": 10, "fontSize": 10, "fontWeight": 600, "color": "#b54e1f"},
      "encoding": {
        "y": {"field": "species", "type": "nominal", "sort": {"field": "max_hop_m", "order": "descending"}},
        "x": {"field": "max_hop_m", "type": "quantitative"},
        "text": {"field": "max_hop_m", "type": "quantitative", "format": ".1f"}
      }
    },
    {
      "data": {"values": [{"x": 2}]},
      "mark": {"type": "rule", "stroke": "#3d2c1a", "strokeDash": [4, 4], "strokeWidth": 1.5, "opacity": 0.7},
      "encoding": {
        "x": {"field": "x", "type": "quantitative"}
      }
    },
    {
      "data": {"values": [{"x": 2, "y_pos": -1, "label": "Human ~2 m"}]},
      "mark": {"type": "text", "color": "#3d2c1a", "fontSize": 10, "fontWeight": 700, "align": "left", "baseline": "bottom", "dx": 4, "dy": -2},
      "encoding": {
        "x": {"field": "x", "type": "quantitative"},
        "text": {"field": "label"}
      }
    }
  ],
  "config": {
    "view": {"stroke": null}
  }
}
