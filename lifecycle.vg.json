            "fontSize": 9,
            "fontWeight": 600,
            "color": "#2d5a3d",
            "lineHeight": 11
          },
          "encoding": {
            "x": { "datum": 16.5, "type": "quantitative" },
            "y": { "value": 14 },
            "text": { "field": "text" }
          }
        },
        {
          "data": { "values": [{}] },
