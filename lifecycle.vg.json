{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "padding": { "top": 16, "bottom": 12, "left": 12, "right": 12 },
  "background": "#fffaf0",
  "data": { "url": "lifecycle.csv" },
  "columns": 2,
  "config": {
    "range": {
      "category": [
        "#5a3a1e",
        "#a07c4e",
        "#2d5a3d",
        "#6b9b7d",
        "#8a6d3b",
        "#b4d4be"
      ]
    }
  },
  "concat": [
    {
      "title": "Red Kangaroo",
      "width": 260,
      "height": 130,
      "transform": [
        { "filter": "indexof(datum.task, 'Red Kangaroo') >= 0" },
        {
          "calculate": "trim(replace(datum.task, /\\s*\\(.*\\)/, ''))",
          "as": "stage"
        }
      ],
      "layer": [
        {
          "mark": "bar",
          "encoding": {
            "y": {
              "field": "stage",
              "type": "ordinal",
              "title": null,
              "axis": { "labelLimit": 200 }
            },
            "x": {
              "field": "start",
              "type": "quantitative",
              "title": "Age (months)"
            },
            "x2": { "field": "end" },
            "color": {
              "field": "stage",
              "type": "nominal",
              "title": "Stage",
              "legend": null
            },
            "tooltip": [
              { "field": "task", "title": "Stage" },
              { "field": "start", "title": "Start (months)" },
              { "field": "end", "title": "End (months)" }
            ]
          }
        },
        {
          "data": { "values": [{}] },
          "mark": {
            "type": "rect",
            "fill": "#fffaf0",
            "fillOpacity": 0.95,
            "stroke": "#2d5a3d",
            "strokeWidth": 1,
            "cornerRadius": 4
          },
          "encoding": {
            "x": { "datum": 12, "type": "quantitative" },
            "x2": { "datum": 21 },
            "y": { "value": 10 },
            "y2": { "value": 36 }
          }
        },
        {
          "data": {
            "values": [{ "text": ["Earliest maturity", "for the joey"] }]
          },
