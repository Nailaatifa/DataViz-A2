{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "padding": {"top": 16, "bottom": 12, "left": 12, "right": 12},
  "background": "#fffaf0",
  "data": {"url": "lifecycle.csv"},
  "columns": 2,
  "config": {
    "range": {
      "category": ["#5a3a1e", "#a07c4e", "#2d5a3d", "#6b9b7d", "#8a6d3b", "#b4d4be"]
    }
  },
  "concat": [
    {
      "title": "Red Kangaroo",
      "width": 260,
      "height": 120,
      "mark": "bar",
      "transform": [
        {"filter": "indexof(datum.task, 'Red Kangaroo') >= 0"},
        {"calculate": "trim(replace(datum.task, /\\s*\\(.*\\)/, ''))", "as": "stage"}
      ],
      "encoding": {
        "y": {"field": "stage", "type": "ordinal", "title": null, "axis": {"labelLimit": 200}},
        "x": {"field": "start", "type": "quantitative", "title": "Age (months)"},
        "x2": {"field": "end"},
        "color": {"field": "stage", "type": "nominal", "title": "Stage", "legend": null},
        "tooltip": [
          {"field": "task", "title": "Stage"},
          {"field": "start", "title": "Start (months)"},
          {"field": "end", "title": "End (months)"}
        ]
      }
    },
    {
      "title": "Eastern Grey Kangaroo",
      "width": 260,
      "height": 120,
      "mark": "bar",
      "transform": [
        {"filter": "indexof(datum.task, 'Eastern Grey') >= 0"},
        {"calculate": "trim(replace(datum.task, /\\s*\\(.*\\)/, ''))", "as": "stage"}
      ],
      "encoding": {
        "y": {"field": "stage", "type": "ordinal", "title": null, "axis": {"labelLimit": 200}},
        "x": {"field": "start", "type": "quantitative", "title": "Age (months)"},
        "x2": {"field": "end"},
        "color": {"field": "stage", "type": "nominal", "title": "Stage", "legend": null},
        "tooltip": [
          {"field": "task", "title": "Stage"},
          {"field": "start", "title": "Start (months)"},
          {"field": "end", "title": "End (months)"}
        ]
      }
    },
    {
      "title": "Western Grey Kangaroo",
      "width": 260,
      "height": 120,
      "mark": "bar",
      "transform": [
        {"filter": "indexof(datum.task, 'Western Grey') >= 0"},
        {"calculate": "trim(replace(datum.task, /\\s*\\(.*\\)/, ''))", "as": "stage"}
      ],
      "encoding": {
        "y": {"field": "stage", "type": "ordinal", "title": null, "axis": {"labelLimit": 200}},
        "x": {"field": "start", "type": "quantitative", "title": "Age (months)"},
        "x2": {"field": "end"},
        "color": {"field": "stage", "type": "nominal", "title": "Stage", "legend": null},
        "tooltip": [
          {"field": "task", "title": "Stage"},
          {"field": "start", "title": "Start (months)"},
          {"field": "end", "title": "End (months)"}
        ]
      }
    },
    {
      "title": "Wallaroo",
      "width": 260,
      "height": 120,
      "mark": "bar",
      "transform": [
        {"filter": "indexof(datum.task, 'Wallaroo') >= 0"},
        {"calculate": "trim(replace(datum.task, /\\s*\\(.*\\)/, ''))", "as": "stage"}
      ],
      "encoding": {
        "y": {"field": "stage", "type": "ordinal", "title": null, "axis": {"labelLimit": 200}},
        "x": {"field": "start", "type": "quantitative", "title": "Age (months)"},
        "x2": {"field": "end"},
        "color": {"field": "stage", "type": "nominal", "title": "Stage", "legend": null},
        "tooltip": [
          {"field": "task", "title": "Stage"},
          {"field": "start", "title": "Start (months)"},
          {"field": "end", "title": "End (months)"}
        ]
      }
    }
  ]
}
