{
    "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
    "title": "Kangaroo Life Cycle Stages (months)",
    "background": "#fffaf0",
    "data": {
        "url": "lifecycle.csv"
    },
    "columns": 2,
    "concat": [
        {
            "title": "Red Kangaroo",
            "layer": [
                {
                    "mark": "bar",
                    "transform": [
                        {
                            "filter": "indexof(datum.task, 'Red Kangaroo') >= 0"
                        },
                        {
                            "calculate": "trim(replace(datum.task, /\\s*\\(.*\\)/, ''))",
                            "as": "stage"
                        }
                    ],
                    "encoding": {
                        "y": {
                            "field": "stage",
                            "type": "ordinal",
                            "title": null,
                            "axis": {
                                "labelLimit": 200
                            }
                        },
                        "x": {
                            "field": "start",
                            "type": "quantitative",
                            "title": "Age (months)"
                        },
                        "x2": {
                            "field": "end"
                        },
                        "color": {
                            "field": "task",
                            "type": "nominal",
                            "title": "Stage",
                            "legend": null
                        },
                        "tooltip": [
                            {
                                "field": "task",
                                "title": "Stage"
                            },
                            {
                                "field": "start",
                                "title": "Start (months)"
                            },
                            {
                                "field": "end",
                                "title": "End (months)"
                            }
                        ]
                    }
                },
                {
                    "data": {
                        "values": [
                            {}
                        ]
                    },
                    "mark": {
                        "type": "text",
                        "align": "right",
                        "baseline": "top",
                        "fontSize": 10,
                        "fontStyle": "italic",
                        "color": "#555",
                        "dx": -4,
                        "dy": 4
                    },
                    "encoding": {
                        "x": {
                            "datum": 24,
                            "type": "quantitative"
                        },
                        "y": {
                            "datum": "Gestation",
