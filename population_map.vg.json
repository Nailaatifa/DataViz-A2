{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": {"top": 16, "bottom": 12, "left": 12, "right": 12},
  "height": 360,
  "width": 400,
  "background": "#fffaf0",
  "projection": {
    "type": "mercator",
    "center": [
      134,
      -27
    ],
    "scale": 520
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/codeforgermany/click_that_hood/main/public/data/australia.geojson",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#dfe9d8",
        "stroke": "#4a7c5e",
        "strokeWidth": 0.6
      }
    },
    {
      "data": {
        "url": "https://biocache-ws.ala.org.au/ws/occurrences/search?q=lsid:https://biodiversity.org.au/afd/taxa/7e6e134b-2bc7-43c4-b23a-6e3f420f57ad%20OR%20lsid:https://biodiversity.org.au/afd/taxa/f2f43ef9-89fd-4f89-8b06-0842e86cfe06%20OR%20lsid:https://biodiversity.org.au/afd/taxa/e9b141fb-9c47-46a3-b631-39b175a2cd74%20OR%20lsid:https://biodiversity.org.au/afd/taxa/e29ab738-af2b-438a-80cf-675a37616ba9%20OR%20lsid:https://biodiversity.org.au/afd/taxa/b9d06f62-63da-4649-80ba-33986ea058e1&pageSize=1000&fl=decimalLatitude,decimalLongitude,vernacularName,scientificName",
        "format": {"type": "json", "property": "occurrences"}
      },
      "transform": [
        {"filter": "datum.decimalLatitude != null && datum.decimalLongitude != null"},
        {
          "calculate": "indexof(datum.scientificName, 'Osphranter rufus') >= 0 ? 'Red Kangaroo' : (indexof(datum.scientificName, 'Macropus giganteus') >= 0 ? 'Eastern Grey Kangaroo' : (indexof(datum.scientificName, 'Macropus fuliginosus') >= 0 ? 'Western Grey Kangaroo' : (indexof(datum.scientificName, 'Osphranter robustus') >= 0 ? 'Common Wallaroo' : (indexof(datum.scientificName, 'Notamacropus eugenii') >= 0 ? 'Tammar Wallaby' : datum.vernacularName))))",
          "as": "speciesGroup"
        }
      ],
      "mark": {
        "type": "circle",
        "opacity": 0.7,
        "size": 28,
        "stroke": null
      },
      "encoding": {
        "longitude": {
          "field": "decimalLongitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "decimalLatitude",
          "type": "quantitative"
        },
        "color": {
          "field": "speciesGroup",
          "type": "nominal",
          "title": "Species",
          "scale": {
            "domain": [
              "Red Kangaroo",
              "Eastern Grey Kangaroo",
              "Western Grey Kangaroo",
              "Common Wallaroo",
              "Tammar Wallaby"
            ],
            "range": ["#b54e1f", "#4a7c5e", "#d4a35c", "#3d2c1a", "#c2c43b"]
          },
          "legend": {
            "orient": "none",
            "legendX": 10,
            "legendY": 10,
            "direction": "vertical",
            "fillColor": "#fffaf0",
            "strokeColor": "#e8d8b8",
            "padding": 8,
            "cornerRadius": 6,
            "labelFontSize": 11,
            "titleFontSize": 12
          }
        },
        "tooltip": [
          {
            "field": "speciesGroup",
            "type": "nominal",
            "title": "Species"
          },
          {
            "field": "scientificName",
            "type": "nominal",
            "title": "Scientific name"
          },
          {
            "field": "decimalLatitude",
            "type": "quantitative",
            "title": "Latitude",
            "format": ".3f"
          },
          {
            "field": "decimalLongitude",
            "type": "quantitative",
            "title": "Longitude",
            "format": ".3f"
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    },
    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "titleFontWeight": 500
    },
    "title": {
      "font": "Lora",
      "fontSize": 15,
      "fontWeight": 700,
      "color": "#2d5a3d",
      "anchor": "start"
    }
  }
}