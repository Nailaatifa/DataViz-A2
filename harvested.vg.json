{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": {"top": 16, "bottom": 12, "left": 12, "right": 12},
  "background": "#fffaf0",
  "width": 540,
  "height": 320,
  "data": {"url": "harvested.csv"},
  "layer": [
    {
      "mark": {
        "type": "line",
        "point": {"filled": true, "size": 60},
        "strokeWidth": 2.5,
        "interpolate": "monotone"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Year"
        },
        "y": {
          "field": "rate",
          "type": "quantitative",
          "title": "Harvest utilisation (% of sustainable quota)",
          "scale": {"domain": [0, 55]}
        },
        "color": {
          "field": "state",
          "type": "nominal",
          "title": "State",
          "scale": {
            "domain": ["NSW", "QLD", "SA", "VIC", "WA"],
            "range": ["#5a3a1e", "#a07c4e", "#2d5a3d", "#6b9b7d", "#8a6d3b"]
          },
          "legend": {"orient": "right"}
        },
        "tooltip": [
          {"field": "state", "type": "nominal", "title": "State"},
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "quota", "type": "quantitative", "title": "Quota", "format": ","},
          {"field": "harvested", "type": "quantitative", "title": "Harvested", "format": ","},
          {"field": "rate", "type": "quantitative", "title": "Utilisation (%)", "format": ".1f"}
        ]
      }
    },
    {
      "data": {"values": [{"year": 2020}]},
      "mark": {
        "type": "rule",
        "color": "#5a3a1e",
        "strokeDash": [4, 4],
        "opacity": 0.55
      },
      "encoding": {
        "x": {"field": "year", "type": "ordinal"}
      }
    },
    {
      "data": {
        "values": [
          {"year": 2020, "y": 52, "label": "2019–20 bushfires"},
          {"year": 2020, "y": 49, "label": "& COVID disruption"}
        ]
      },
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "bottom",
        "fontStyle": "italic",
        "fontSize": 11,
        "color": "#3d2c1a"
      },
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "y", "type": "quantitative"},
        "text": {"field": "label"}
      }
    },
    {
      "data": {
        "values": [
          {"year": 2024, "y": 46, "label": "SA — highest year-on-year"},
          {"year": 2024, "y": 20, "label": "VIC — smallest program"}
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "fontSize": 10,
        "fontStyle": "italic",
        "color": "#5a3a1e",
        "dx": 6
      },
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "y", "type": "quantitative"},
        "text": {"field": "label"}
      }
    },
    {
      "data": {"values": [{"y": 30, "label": "national average ≈ 30%"}]},
      "mark": {
        "type": "rule",
        "color": "#6b4423",
        "strokeDash": [2, 4],
        "opacity": 0.4
      },
      "encoding": {
        "y": {"field": "y", "type": "quantitative"}
      }
    },
    {
      "data": {"values": [{"year": 2018, "y": 31, "label": "≈ 30% national average"}]},
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "fontSize": 10,
        "fontStyle": "italic",
        "color": "#6b4423"
      },
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "y", "type": "quantitative"},
        "text": {"field": "label"}
      }
    }
  ]
}
