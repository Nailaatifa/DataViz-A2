{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": {"top": 16, "bottom": 12, "left": 12, "right": 12},
  "background": "#fffaf0",
  "width": 500,
  "height": 280,
  "data": {"url": "harvested.csv"},
  "transform": [
    {"fold": ["quota", "harvested"], "as": ["category", "count"]},
    {
      "calculate": "datum.category === 'quota' ? 'Sustainable Quota' : 'Actually Harvested'",
      "as": "label"
    }
  ],
  "mark": {"type": "bar", "cornerRadiusEnd": 4},
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": "Year"
    },
    "y": {
      "field": "count",
      "type": "quantitative",
      "title": "Kangaroos",
      "axis": {"format": "~s"}
    },
    "color": {
      "field": "label",
      "type": "nominal",
      "scale": {
        "domain": ["Sustainable Quota", "Actually Harvested"],
        "range": ["#a07c4e", "#5a3a1e"]
      },
      "title": null,
      "legend": {"orient": "bottom"}
    },
    "xOffset": {"field": "label"},
    "tooltip": [
      {"field": "year", "type": "ordinal", "title": "Year"},
      {"field": "label", "type": "nominal", "title": "Category"},
      {"field": "count", "type": "quantitative", "title": "Kangaroos", "format": ","}
    ]
  }
}
