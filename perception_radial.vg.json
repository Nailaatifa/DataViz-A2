{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "padding": {
        "top": 16,
        "left": 0,
        "right": 12
    },
    "description": "Australian perceptions of kangaroos (radial bar)",
    "background": "#fffaf0",
    "width": 250,
    "height": 250,
    "data": {
        "url": "perception.csv"
    },
    "encoding": {
        "theta": {
            "field": "Percentage",
            "type": "quantitative",
            "stack": true
        },
        "radius": {
            "field": "Percentage",
            "type": "quantitative",
            "scale": {
                "type": "sqrt",
                "zero": true,
                "range": [20, 110]
            }
        },
        "color": {
            "field": "Perception",
            "type": "nominal",
            "legend": {
                "title": "Perception",
                "orient": "right",
                "labelFontSize": 12,
                "titleFontSize": 12,
                "symbolSize": 120
            },
            "scale": {
                "range": [
                    "#5a3a1e",
                    "#6a4724",
                    "#7a5a2a",
                    "#8a6d30",
                    "#7a7f33",
                    "#5f8f3a",
                    "#3fa34d",
                    "#2e8b57",
                    "#b7e4c7"
                ]
            }
        }
    },
    "layer": [
        {
            "params": [
                {
                    "name": "perceptionSel",
                    "select": {"type": "point", "fields": ["Perception"]},
                    "bind": "legend"
                }
            ],
            "mark": {
                "type": "arc",
                "innerRadius": 20,
                "stroke": "#fff",
                "strokeWidth": 2
            },
            "encoding": {
                "opacity": {
                    "condition": {"param": "perceptionSel", "value": 1},
                    "value": 0.2
                }
            }
        },
        {
            "mark": {
                "type": "text",
                "radiusOffset": 14,
                "fontSize": 12,
                "fontWeight": "bold"
            },
            "encoding": {
                "text": {
                    "field": "Percentage",
                    "type": "quantitative",
                    "format": ".1f"
                }
            }
        }
    ]
}
