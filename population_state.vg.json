{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "padding": {"top": 16, "bottom": 12, "left": 12, "right": 12},
  "description": "Kangaroo population by species per state, grouped by year",
  "background": "#fffaf0",
  "width": 360,
  "height": 320,
  "data": {"url": "population_state.csv"},
  "params": [
    {"name": "speciesFilter", "value": "all"},
    {"name": "yearMin", "value": 2010},
    {"name": "yearMax", "value": 2024},
    {
      "name": "selectedYear",
      "value": 2024,
      "bind": {
        "input": "select",
        "options": [2010, 2011, 2012, 2013, 2014, 2015, 2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023, 2024],
        "name": "Year: "
      }
    }
  ],
  "transform": [
    {"filter": "datum.Species != 'Euro'"},
    {"filter": "datum.Year >= yearMin && datum.Year <= yearMax"},
    {"filter": "datum.Year == selectedYear"},
    {
      "calculate": "datum.State == 'NSW' ? 'New South Wales' : datum.State == 'QLD' ? 'Queensland' : datum.State == 'SA' ? 'South Australia' : datum.State == 'VIC' ? 'Victoria' : datum.State == 'WA' ? 'Western Australia' : datum.State",
      "as": "StateName"
    }
  ],
  "mark": "rect",
  "encoding": {
    "x": {
      "field": "State",
      "type": "nominal",
      "title": "State"
    },
    "y": {
      "field": "Species",
      "type": "nominal",
      "title": "Species"
    },
    "color": {
      "aggregate": "sum",
      "field": "Population",
      "type": "quantitative",
      "title": "Population",
      "scale": {
        "scheme": "browns",
        "domain": [0, 18252150]
      }
    },
    "opacity": {
      "condition": {
        "test": "speciesFilter == 'all' || datum.Species == speciesFilter",
        "value": 1
      },
      "value": 0.18
    },
    "tooltip": [
      {"field": "State", "type": "nominal"},
      {"field": "StateName", "type": "nominal", "title": "State name"},
      {"field": "Species", "type": "nominal"},
      {
        "aggregate": "sum",
        "field": "Population",
        "title": "Total Population",
        "format": ","
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    }
  }
}
