{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "Kangaroo Species Population by Year",
    "width": 580,
    "height": 300,
    "background": "#fffaf0",
    "data": {
        "url": "population_yearly.csv"
    },
    "mark": "area",
    "params": [
        {
            "name": "species",
            "select": {
                "type": "point",
                "fields": [
                    "series"
                ]
            },
            "bind": "legend"
        }
    ],
    "encoding": {
        "x": {
            "timeUnit": "year",
            "field": "date",
            "type": "temporal",
            "axis": {
                "format": "%Y",
                "title": "Year"
            }
        },
        "y": {
            "aggregate": "sum",
            "field": "count",
            "type": "quantitative",
            "axis": {
                "title": "Total Population"
            }
        },
        "color": {
            "field": "series",
            "type": "nominal",
            "title": "Species",
            "scale": {
                "scheme": "category20b"
            }
        },
        "opacity": {
            "condition": {
                "param": "species",
                "value": 1
            },
            "value": 0.2
        }
    }
}