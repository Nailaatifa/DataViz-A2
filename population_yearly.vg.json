{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": { "top": 0, "bottom": 12, "left": 12, "right": 12 },
  "background": "#fffaf0",
  "data": {
    "url": "population_yearly.csv"
  },
  "params": [
    { "name": "speciesFilter", "value": "all" },
    { "name": "yearMin", "value": 2010 },
    { "name": "yearMax", "value": 2024 }
  ],
  "vconcat": [
    {
      "width": 700,
      "height": 380,
      "encoding": {
        "x": {
          "timeUnit": "year",
          "field": "date",
          "type": "temporal",
          "scale": {
            "domain": {
              "param": "brush"
            }
          },
          "axis": {
            "format": "%Y",
            "title": "Year"
          }
        }
      },
      "layer": [
        {
          "mark": "area",
          "params": [
            {
              "name": "species",
              "select": {
                "type": "point",
                "fields": ["series"]
              },
              "bind": "legend"
            }
          ],
          "encoding": {
            "y": {
              "aggregate": "sum",
              "field": "count",
              "type": "quantitative",
              "axis": {
                "title": "Total Population"
              }
            },
            "color": {
              "field": "series",
              "type": "nominal",
              "title": "Species",
              "scale": {
                "domain": [
                  "Eastern Grey Kangaroo",
                  "Grey Kangaroo",
                  "Red Kangaroo",
                  "Tammar Wallaby",
                  "Wallaroo",
                  "Western Grey Kangaroo"
                ],
                "range": [
                  "#e3891f",
                  "#c56a1a",
                  "#f2b705",
                  "#2e8b57",
                  "#d4d83b",
                  "#7fbf3f"
                ]
              },
              "legend": {
                "orient": "none",
                "legendX": 542,
                "legendY": -10,
                "direction": "vertical",
                "fillColor": "#fffaf0",
                "strokeColor": "#e8d8b8",
                "padding": 8,
                "cornerRadius": 6,
                "labelFontSize": 11,
                "titleFontSize": 12,
                "symbolSize": 120
              }
            },
            "opacity": {
              "condition": [
                {
                  "test": "speciesFilter != 'all' && datum.series != speciesFilter",
                  "value": 0.15
                },
                {
                  "param": "species",
                  "value": 1
                }
              ],
              "value": 0.2
            }
          }
        }
      ]
    },
    {
      "width": 700,
      "height": 60,
      "mark": {
        "type": "area",
        "color": "#a07c4e"
      },
      "params": [
        {
          "name": "brush",
          "select": {
            "type": "interval",
            "encodings": ["x"]
          }
        }
      ],
      "encoding": {
        "x": {
          "timeUnit": "year",
          "field": "date",
          "type": "temporal",
          "axis": {
            "format": "%Y",
            "title": "",
            "tickCount": 10
          }
        },
        "y": {
          "aggregate": "sum",
          "field": "count",
          "type": "quantitative",
          "axis": {
            "tickCount": 3,
            "grid": false,
            "title": ""
          }
        }
      }
    }
  ]
}
