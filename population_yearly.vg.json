{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "Kangaroo Species Population by Year",
    "width": 580,
    "height": 300,
    "background": "#fffaf0",
    "data": {
        "url": "population_yearly.csv"
    },
    "mark": "area",
    "params": [
        {
            "name": "species",
            "select": {
                "type": "point",
                "fields": [
                    "series"
                ]
            },
            "bind": "legend"
        }
    ],
    "encoding": {
        "x": {
            "timeUnit": "year",
            "field": "date",
            "type": "temporal",
            "axis": {
                "format": "%Y",
                "title": "Year"
            }
        },
        "y": {
            "aggregate": "sum",
            "field": "count",
            "type": "quantitative",
            "axis": {
                "title": "Total Population"
            }
        },
        "color": {
            "field": "series",
            "type": "nominal",
            "title": "Species",
            "scale": {
                "domain": [
                    "Eastern Grey Kangaroo",
                    "Euro",
                    "Grey Kangaroo",
                    "Red Kangaroo",
                    "Tammar Wallaby",
                    "Wallaroo",
                    "Western Grey Kangaroo"
                ],
                "range": [
                    "#e3891f",
                    "#8c4f1f",
                    "#c56a1a",
                    "#f2b705",
                    "#2e8b57",
                    "#d4d83b",
                    "#7fbf3f"
                ]
            }
        },
        "opacity": {
            "condition": {
                "param": "species",
                "value": 1
            },
            "value": 0.2
        }
    }
}