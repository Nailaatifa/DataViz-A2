{
    "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
    "title": {
        "text": "Body Weight by Species and Sex",
        "anchor": "middle",
        "fontSize": 22,
        "color": "#2d5a3d",
        "fontWeight": 700,
        "font": "Lora, Times New Roman, serif",
        "offset": 18
    },
    "padding": {"top": 16, "bottom": 12, "left": 12, "right": 12},
    "data": {
        "url": "weight.csv"
    },
    "background": "#fffaf0",
    "repeat": {
        "layer": [
            "Male Weight",
            "Female Weight"
        ]
    },
    "spec": {
        "mark": "bar",
        "encoding": {
            "x": {
                "field": "species",
                "type": "nominal",
                "axis": {
                    "labelAngle": -35,
                    "labelAlign": "right",
                    "labelBaseline": "middle"
                }
            },
            "y": {
                "aggregate": "sum",
                "field": {
                    "repeat": "layer"
                },
                "type": "quantitative",
                "title": "Weight (kg)"
            },
            "color": {
                "datum": {
                    "repeat": "layer"
                },
                "title": null,
                "scale": {
                    "domain": ["Male Weight", "Female Weight"],
                    "range": ["#6b4423", "#4a7c5e"]
                },
                "legend": {
                    "orient": "none",
                    "legendX": 20,
                    "legendY": 5,
                    "direction": "vertical",
                    "fillColor": "#fffaf0",
                    "strokeColor": "#e8d8b8",
                    "padding": 8,
                    "cornerRadius": 6
                }
            },
            "xOffset": {
                "datum": {
                    "repeat": "layer"
                }
            }
        }
    },
    "config": {
        "mark": {
            "invalid": null
        }
    }
}