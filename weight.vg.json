{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": { "top": 16, "bottom": 12, "left": 12, "right": 12 },
  "background": "#fffaf0",
  "width": 300,
  "height": 300,
  "data": { "url": "weight.csv" },
  "params": [
    { "name": "unitParam", "value": "kg" },
    { "name": "speciesFilter", "value": "all" }
  ],
  "transform": [
    {
      "calculate": "unitParam == 'lb' ? datum['Male Weight'] * 2.20462 : datum['Male Weight']",
      "as": "Male Weight"
    },
    {
      "calculate": "unitParam == 'lb' ? datum['Female Weight'] * 2.20462 : datum['Female Weight']",
      "as": "Female Weight"
    }
  ],
  "encoding": {
    "y": {
      "field": "species",
      "type": "nominal",
      "sort": [
        "Red Kangaroo",
        "Eastern Grey Kangaroo",
        "Western Grey Kangaroo",
        "Wallaroo",
        "Tammar Wallaby"
      ],
      "title": null,
      "axis": {
        "labelFontSize": 11,
        "labelColor": "#3d2c1a",
        "labelPadding": 6,
        "labelLineHeight": 12,
        "labelExpr": "test(/ Kangaroo$/, datum.value) ? [replace(datum.value, ' Kangaroo', ''), 'Kangaroo'] : (test(/ Wallaby$/, datum.value) ? [replace(datum.value, ' Wallaby', ''), 'Wallaby'] : datum.value)"
      }
    }
  },
  "layer": [
    {
      "mark": "bar",
      "encoding": {
        "x": {
          "field": "Male Weight",
          "type": "quantitative",
          "title": {
            "signal": "unitParam == 'lb' ? 'Weight (lb)' : 'Weight (kg)'"
          }
        },
        "color": {
          "datum": "Male Weight",
          "title": null,
          "scale": {
            "domain": ["Male Weight", "Female Weight"],
            "range": ["#c56a1a", "#f2b705"]
          },
          "legend": {
            "orient": "none",
            "legendX": 210,
            "legendY": 240,
            "direction": "vertical",
            "fillColor": "#fffaf0",
            "strokeColor": "#e8d8b8",
            "padding": 6,
            "cornerRadius": 6,
            "labelFontSize": 10
          }
        },
        "yOffset": { "datum": "Male Weight" },
        "opacity": {
          "condition": {
            "test": "speciesFilter == 'all' || datum.species == speciesFilter",
            "value": 1
          },
          "value": 0.18
        },
        "tooltip": [
          { "field": "species", "type": "nominal", "title": "Species" },
          {
            "field": "Male Weight",
            "type": "quantitative",
            "format": ".1f",
            "title": {
              "signal": "unitParam == 'lb' ? 'Male weight (lb)' : 'Male weight (kg)'"
            }
          }
        ]
      }
    },
    {
      "mark": "bar",
      "encoding": {
        "x": {
          "field": "Female Weight",
          "type": "quantitative"
        },
        "color": {
          "datum": "Female Weight",
          "scale": {
            "domain": ["Male Weight", "Female Weight"],
            "range": ["#c56a1a", "#f2b705"]
          }
        },
        "yOffset": { "datum": "Female Weight" },
        "opacity": {
          "condition": {
            "test": "speciesFilter == 'all' || datum.species == speciesFilter",
            "value": 1
          },
          "value": 0.18
        },
        "tooltip": [
          { "field": "species", "type": "nominal", "title": "Species" },
          {
            "field": "Female Weight",
            "type": "quantitative",
            "format": ".1f",
            "title": {
              "signal": "unitParam == 'lb' ? 'Female weight (lb)' : 'Female weight (kg)'"
            }
          }
        ]
      }
    },
    {
      "data": { "values": [{ "species": "Tammar Wallaby" }] },
      "mark": {
        "type": "rect",
        "fill": "#fffaf0",
        "fillOpacity": 0.95,
        "stroke": "#8a6d3b",
        "strokeWidth": 1,
        "cornerRadius": 4,
        "yOffset": -5,
        "y2Offset": 5
      },
      "encoding": {
        "x": { "datum": 12, "type": "quantitative" },
        "x2": { "datum": 60 },
        "y": { "field": "species", "type": "nominal" }
      }
    },
    {
      "data": {
        "values": [
          {
            "species": "Tammar Wallaby",
            "text": "~8× smaller than Wallaroo"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "fontSize": 10,
        "fontWeight": 700,
        "color": "#5a3a1e"
      },
      "encoding": {
        "x": { "datum": 36, "type": "quantitative" },
        "y": { "field": "species", "type": "nominal" },
        "text": { "field": "text" }
      }
    },
    {
      "data": { "values": [{ "species": "Tammar Wallaby" }] },
      "mark": {
        "type": "rule",
        "stroke": "#8a6d3b",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": { "datum": 12, "type": "quantitative" },
        "x2": { "datum": 8 },
        "y": { "field": "species", "type": "nominal" }
      }
    }
  ],
  "config": {
    "mark": { "invalid": null }
  }
}
