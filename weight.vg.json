{
    "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
    "padding": {"top": 16, "bottom": 12, "left": 12, "right": 12},
    "data": {
        "url": "weight.csv"
    },
    "background": "#fffaf0",
    "repeat": {
        "layer": [
            "Male Weight",
            "Female Weight"
        ]
    },
    "spec": {
        "width": 300,
        "height": 300,
        "mark": "bar",
        "encoding": {
            "x": {
                "field": "species",
                "type": "nominal",
                "axis": {
                    "labelAngle": -30,
                    "labelAlign": "right",
                    "labelBaseline": "middle"
                }
            },
            "y": {
                "aggregate": "sum",
                "field": {
                    "repeat": "layer"
                },
                "type": "quantitative",
                "title": "Weight (kg)"
            },
            "color": {
                "datum": {
                    "repeat": "layer"
                },
                "title": null,
                "scale": {
                    "domain": ["Male Weight", "Female Weight"],
                    "range": ["#c56a1a", "#f2b705"]
                },
                "legend": {
                    "orient": "none",
                    "legendX": 180,
                    "legendY": 5,
                    "direction": "vertical",
                    "fillColor": "#fffaf0",
                    "strokeColor": "#e8d8b8",
                    "padding": 6,
                    "cornerRadius": 6,
                    "labelFontSize": 10
                }
            },
            "xOffset": {
                "datum": {
                    "repeat": "layer"
                }
            }
        }
    },
    "config": {
        "mark": {
            "invalid": null
        }
    }
}