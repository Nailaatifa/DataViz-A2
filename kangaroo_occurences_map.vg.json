{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": {"top": 10, "bottom": 0, "left": 12, "right": 12},
  "height": 320,
  "width": 400,
  "background": "#fffaf0",
  "projection": {
    "type": "mercator",
    "center": [
      134,
      -27
    ],
    "scale": 520
  },
  "params": [
    {"name": "speciesFilter", "value": "all"}
  ],
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/codeforgermany/click_that_hood/main/public/data/australia.geojson",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "transform": [
        {"filter": "datum.properties.name != 'Tasmania'"}
      ],
      "mark": {
        "type": "geoshape",
        "fill": "#5a3a1e",
        "stroke": "#a07c4e",
        "strokeWidth": 0.6
      }
    },
    {
      "data": {
        "url": "kangaroo_occurrences.json",
        "format": {"type": "json"}
      },
      "transform": [
        {
          "calculate": "indexof(datum.scientificName, 'Osphranter rufus') >= 0 ? 'Red Kangaroo' : (indexof(datum.scientificName, 'Macropus giganteus') >= 0 ? 'Eastern Grey Kangaroo' : (indexof(datum.scientificName, 'Macropus fuliginosus') >= 0 ? 'Western Grey Kangaroo' : (indexof(datum.scientificName, 'Osphranter robustus') >= 0 ? 'Wallaroo' : (indexof(datum.scientificName, 'Notamacropus eugenii') >= 0 ? 'Tammar Wallaby' : datum.vernacularName))))",
          "as": "speciesGroup"
        }
      ],
      "params": [
        {
          "name": "speciesSel",
          "select": {"type": "point", "fields": ["speciesGroup"]},
          "bind": "legend"
        }
      ],
      "mark": {
        "type": "circle",
        "size": 28,
        "stroke": null
      },
      "encoding": {
        "longitude": {
          "field": "decimalLongitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "decimalLatitude",
          "type": "quantitative"
        },
        "opacity": {
          "condition": {
            "test": "speciesFilter == 'all' || datum.speciesGroup == speciesFilter",
            "value": 0.85
          },
          "value": 0.12
        },
        "color": {
          "field": "speciesGroup",
          "type": "nominal",
          "title": "Species",
          "scale": {
           "domain": [
                                    "Eastern Grey Kangaroo",
                                    "Red Kangaroo",
                                    "Tammar Wallaby",
                                    "Wallaroo",
                                    "Western Grey Kangaroo"
                                ],
                                "range": [
                                    "#e3891f",
                                    "#f2b705",
                                    "#2e8b57",
                                    "#d4d83b",
                                    "#7fbf3f"
                                ]
          },
          "legend": {
            "orient": "right",
            "direction": "vertical",
            "fillColor": "#fffaf0",
            "strokeColor": "#e8d8b8",
            "padding": 10,
            "cornerRadius": 6,
            "labelFontSize": 11,
            "titleFontSize": 12,
            "symbolSize": 120,
            "offset": 16
          }
        },
        "tooltip": [
          {
            "field": "speciesGroup",
            "type": "nominal",
            "title": "Species"
          },
          {
            "field": "scientificName",
            "type": "nominal",
            "title": "Scientific name"
          },
          {
            "field": "decimalLatitude",
            "type": "quantitative",
            "title": "Latitude",
            "format": ".3f"
          },
          {
            "field": "decimalLongitude",
            "type": "quantitative",
            "title": "Longitude",
            "format": ".3f"
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    },
    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "titleFontWeight": 500
    }
  }
}