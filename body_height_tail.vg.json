{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": {"top": 16, "bottom": 12, "left": 12, "right": 12},
  "background": "#fffaf0",
  "width": 300,
  "height": 300,
  "data": {"url": "body_height_tail.csv"},
  "transform": [
    {
      "pivot": "metric",
      "value": "value_cm",
      "groupby": ["species", "sex"]
    }
  ],
  "mark": {"type": "point", "filled": true, "size": 140, "opacity": 0.85},
  "encoding": {
    "x": {
      "field": "Height",
      "type": "quantitative",
      "title": "Standing height (cm)",
      "scale": {"zero": false, "padding": 10}
    },
    "y": {
      "field": "Tail",
      "type": "quantitative",
      "title": "Tail length (cm)",
      "scale": {"zero": false, "padding": 10}
    },
    "color": {
      "field": "species",
      "type": "nominal",
      "title": "Species",
      "scale": {
        "domain": [
          "Red Kangaroo",
          "Eastern Grey Kangaroo",
          "Western Grey Kangaroo",
          "Wallaroo",
          "Tammar Wallaby"
        ],
        "range": ["#b54e1f", "#4a7c5e", "#d4a35c", "#3d2c1a", "#c2c43b"]
      },
      "legend": {
        "orient": "none",
        "legendX": 10,
        "legendY": 8,
        "direction": "vertical",
        "fillColor": "#fffaf0",
        "strokeColor": "#e8d8b8",
        "padding": 6,
        "cornerRadius": 6,
        "labelFontSize": 10
      }
    },
    "shape": {
      "field": "sex",
      "type": "nominal",
      "title": "Sex",
      "scale": {
        "domain": ["Male", "Female"],
        "range": ["circle", "triangle-up"]
      },
      "legend": {
        "orient": "none",
        "legendX": 10,
        "legendY": 120,
        "direction": "vertical",
        "fillColor": "#fffaf0",
        "strokeColor": "#e8d8b8",
        "padding": 6,
        "cornerRadius": 6,
        "labelFontSize": 10
      }
    },
    "tooltip": [
      {"field": "species", "type": "nominal", "title": "Species"},
      {"field": "sex", "type": "nominal", "title": "Sex"},
      {"field": "Height", "type": "quantitative", "title": "Height (cm)"},
      {"field": "Tail", "type": "quantitative", "title": "Tail (cm)"}
    ]
  }
}
