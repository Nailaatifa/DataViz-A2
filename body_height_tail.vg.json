{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": { "top": 16, "bottom": 12, "left": 12, "right": 12 },
  "background": "#fffaf0",
  "width": 300,
  "height": 300,
  "data": { "url": "body_height_tail.csv" },
  "params": [
    { "name": "unitParam", "value": "kg" },
    { "name": "speciesFilter", "value": "all" }
  ],
  "transform": [
    {
      "pivot": "metric",
      "value": "value_cm",
      "groupby": ["species", "sex"]
    },
    {
      "calculate": "unitParam == 'lb' ? datum.Height / 2.54 : datum.Height",
      "as": "Height"
    },
    {
      "calculate": "unitParam == 'lb' ? datum.Tail / 2.54 : datum.Tail",
      "as": "Tail"
    }
  ],
  "layer": [
    {
      "mark": { "type": "point", "filled": true, "size": 140 },
      "encoding": {
        "x": {
          "field": "Height",
          "type": "quantitative",
          "title": {
            "signal": "unitParam == 'lb' ? 'Standing height (in)' : 'Standing height (cm)'"
          },
          "scale": { "zero": false, "padding": 10 }
        },
        "y": {
          "field": "Tail",
          "type": "quantitative",
          "title": {
            "signal": "unitParam == 'lb' ? 'Tail length (in)' : 'Tail length (cm)'"
          },
          "scale": { "zero": false, "padding": 10 }
        },
        "color": {
          "field": "species",
          "type": "nominal",
          "title": "Species",
          "scale": {
            "domain": [
              "Eastern Grey Kangaroo",
              "Red Kangaroo",
              "Tammar Wallaby",
              "Wallaroo",
              "Western Grey Kangaroo"
            ],
            "range": ["#e3891f", "#f2b705", "#2e8b57", "#d4d83b", "#7fbf3f"]
          },
          "legend": {
            "orient": "none",
            "legendX": 10,
            "legendY": 8,
            "direction": "vertical",
            "fillColor": "#fffaf0",
            "strokeColor": "#e8d8b8",
            "padding": 6,
            "cornerRadius": 6,
            "labelFontSize": 10
          }
        },
        "shape": {
          "field": "sex",
          "type": "nominal",
          "title": "Sex",
          "scale": {
            "domain": ["Male", "Female"],
            "range": ["circle", "triangle-up"]
          },
          "legend": {
            "orient": "none",
            "legendX": 10,
            "legendY": 120,
            "direction": "vertical",
            "fillColor": "#fffaf0",
            "strokeColor": "#e8d8b8",
            "padding": 6,
            "cornerRadius": 6,
            "labelFontSize": 10
          }
        },
        "opacity": {
          "condition": {
            "test": "speciesFilter == 'all' || datum.species == speciesFilter",
            "value": 0.9
          },
          "value": 0.18
        },
        "tooltip": [
          { "field": "species", "type": "nominal", "title": "Species" },
          { "field": "sex", "type": "nominal", "title": "Sex" },
          {
            "field": "Height",
            "type": "quantitative",
            "format": ".1f",
            "title": {
              "signal": "unitParam == 'lb' ? 'Height (in)' : 'Height (cm)'"
            }
          },
          {
            "field": "Tail",
            "type": "quantitative",
            "format": ".1f",
            "title": {
              "signal": "unitParam == 'lb' ? 'Tail (in)' : 'Tail (cm)'"
            }
          }
        ]
      }
    },
    {
      "data": { "values": [{}] },
      "mark": {
        "type": "rect",
        "fill": "#fffaf0",
        "fillOpacity": 0.95,
        "stroke": "#b58200",
        "strokeWidth": 1,
        "cornerRadius": 4
      },
      "encoding": {
        "x": { "datum": 112, "type": "quantitative" },
        "x2": { "datum": 158 },
        "y": { "datum": 36, "type": "quantitative" },
        "y2": { "datum": 48 }
      }
    },
    {
      "data": {
        "values": [{ "text": ["Biggest in", "both sexes"] }]
      },
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "fontSize": 10,
        "fontWeight": 700,
        "color": "#b58200",
        "lineHeight": 12
      },
      "encoding": {
        "x": { "datum": 135, "type": "quantitative" },
        "y": { "datum": 42, "type": "quantitative" },
        "text": { "field": "text" }
      }
    },
    {
      "data": { "values": [{}] },
      "mark": {
        "type": "rule",
        "stroke": "#b58200",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": { "datum": 148, "type": "quantitative" },
        "x2": { "datum": 150 },
        "y": { "datum": 48, "type": "quantitative" },
        "y2": { "datum": 98 }
      }
    },
    {
      "data": { "values": [{}] },
      "mark": {
        "type": "rule",
        "stroke": "#b58200",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": { "datum": 118, "type": "quantitative" },
        "x2": { "datum": 107 },
        "y": { "datum": 48, "type": "quantitative" },
        "y2": { "datum": 79 }
      }
    }
  ]
}
